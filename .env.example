OPENAI_API_KEY=
SMALL_MODEL=gpt-5-mini
ANALYST_MODEL=gpt-5-mini
WRITER_MODEL=gpt-5.4
WRITER_REASONING_EFFORT=medium
ORCHESTRATOR_MODEL=gpt-5-mini
ORCHESTRATOR_REASONING_EFFORT=medium
IMAGE_MODEL=gpt-image-1.5
ARTICLE_IMAGE_COUNT=3
ARTICLE_IMAGE_SIZE=1536x1024
ARTICLE_IMAGE_QUALITY=high
MAX_URLS=3
APP_HOST=0.0.0.0
APP_PORT=8000
APP_BRAND_NAME=Content Workspace
APP_PRODUCT_NAME=Content Workspace
APP_LOGO_PATH=
APP_WORDMARK_TEXT=CONTENT
APP_NAV_EYEBROW=Content Operations
SESSION_TTL_DAYS=30
COOKIE_SECURE=false
ENABLE_SCHEDULER=true
VISIBILITY_ONLY=false
DATABASE_URL=
APP_DB_PATH=data/seo_agent.db
CONTENT_AGENT_SEARCH_ENABLED=true
CONTENT_AGENT_SEARCH_RESULT_COUNT=3
CONTENT_AGENT_BROWSER_FALLBACK_ENABLED=true
CONTENT_AGENT_BROWSER_TIMEOUT_MS=18000

# Optional: Paid search provider key for Content Agent source discovery.
SERPER_API_KEY=

# Optional Google export settings (not required for MVP).
GOOGLE_DOCS_FOLDER_ID=
GOOGLE_SHEET_ID=
